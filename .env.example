# =============================================================================
# OTT Streaming Platform — Phase 0 Environment Template
# Copy backend vars into backend/.env.local and frontend vars into
# frontend/.env.local. NEVER commit real secrets. (.env.local is git-ignored.)
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND (FastAPI)  ->  backend/.env.local
# -----------------------------------------------------------------------------

# App
APP_ENV=local                       # local | staging | production
APP_NAME=ott-backend
API_V1_PREFIX=/api/v1
BACKEND_PORT=8001

# Database — SQLite by default (zero install). For Postgres, set a full URL:
#   DATABASE_URL=postgresql+psycopg://ott:ott_dev@localhost:5432/ott_platform
DATABASE_URL=sqlite:///./ott_phase0.sqlite3

# Redis — optional. Leave blank to use the in-memory fallback (dev only).
#   REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# CORS — explicit frontend origin allowlist (comma-separated). No wildcard.
CORS_ALLOW_ORIGINS=http://localhost:3000

# Auth verification — where the backend reaches Better Auth (Next.js) to verify sessions.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_VERIFY_PATH=/api/auth/get-session
SESSION_VERIFY_CACHE_TTL_SECONDS=10

# Rate limiting (per IP + identity)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Observability
LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=                          # inert when blank
OTEL_EXPORTER_OTLP_ENDPOINT=         # no-op tracing when blank
OTEL_SERVICE_NAME=ott-backend

# -----------------------------------------------------------------------------
# FRONTEND (Next.js)  ->  frontend/.env.local
# -----------------------------------------------------------------------------

# Public
NEXT_PUBLIC_API_BASE=http://localhost:8001
NEXT_PUBLIC_APP_NAME=OTT Platform

# Better Auth (server)
BETTER_AUTH_SECRET=dev-only-secret-change-me-please-32chars-min
BETTER_AUTH_URL=http://localhost:3000

# Better Auth database — SQLite by default. For Postgres set:
#   AUTH_DATABASE_URL=postgres://ott:ott_dev@localhost:5432/ott_platform
AUTH_DATABASE_URL=

# OAuth providers — OPTIONAL. Leave blank to disable a provider locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Sentry (frontend) — inert when blank
NEXT_PUBLIC_SENTRY_DSN=
