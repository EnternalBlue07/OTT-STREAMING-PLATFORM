# ============================================================
# OTT Streaming Platform — Environment Variables
# ============================================================
# Copy this file and fill in your values:
#   Backend:  backend/.env.local
#   Frontend: frontend/.env.local
#
# For Render.com deployment: set these in the Render dashboard
# For Netlify deployment: set NEXT_PUBLIC_API_BASE in Netlify UI
# ============================================================

# --- Backend (FastAPI) ---
APP_ENV=local                          # local | production
APP_NAME=ott-backend
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./ott_phase0.sqlite3
REDIS_URL=                             # leave blank for in-memory fallback
CORS_ALLOW_ORIGINS=http://localhost:3000  # comma-separated; add Netlify URL for prod
BETTER_AUTH_URL=http://localhost:3000     # your frontend URL
BETTER_AUTH_VERIFY_PATH=/api/auth/get-session
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=                            # optional: Sentry error tracking
OTEL_EXPORTER_OTLP_ENDPOINT=          # optional: OpenTelemetry
OTEL_SERVICE_NAME=ott-backend

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://localhost:8001  # change to Render URL for production
NEXT_PUBLIC_APP_NAME=OTT Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to Netlify URL for production
BETTER_AUTH_SECRET=dev-only-secret-change-me-please-32chars-min  # CHANGE IN PROD!
BETTER_AUTH_URL=http://localhost:3000
AUTH_SQLITE_PATH=./auth.sqlite

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
