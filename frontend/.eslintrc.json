{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@/features/*/components/*", "@/features/*/hooks/*", "@/features/*/store/*"],
            "message": "Do not import another feature's deep internals. Import from the feature root or promote to @/shared."
          }
        ]
      }
    ]
  }
}
